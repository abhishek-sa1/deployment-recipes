---
kernel: 'http://{{ 172.16.0.254 }}:9000/boot-images/efi-images/compute/base/vmlinuz-6.12.0-119.el10.x86_64'
initrd: 'http://{{ 172.16.0.254 }}:9000/boot-images/efi-images/compute/base/initramfs-6.12.0-119.el10.x86_64.img'
params: 'nomodeset ro root=live:http://{{ 172.16.0.254 }}:9000/boot-images/compute/base/rhel10.1-compute-base-rhel10.1 squashfs rd.live.image rd.luks=0 rd.md=0 rd.dm=0 ip=dhcp rd.neednet=1 rd.timeout=180 rd.retry=5 selinux=0 apparmor=0 console=tty0 console=ttyS0,115200n8 ip6=off cloud-init=enabled ds=nocloud-net;s=http://{{ 172.16.0.254 }}:8081/cloud-init default_hugepagesz=1G hugepagesz=1G hugepages=128 numa_balancing=disable'
macs:
{% for item in nodes %}
  - {{ item.interfaces[0].mac_addr }}
{% endfor %}
